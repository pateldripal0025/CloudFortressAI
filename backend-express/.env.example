# ====================================================================
# CloudFortress AI: Express Backend Environment Configuration
# Copy this file to '.env' and update variables for your target env.
# ====================================================================

# --------------------------------------------------------------------
# Server Settings
# --------------------------------------------------------------------
# Port to bind the server to (production default: 5001)
PORT=5001

# Application environment (production, development, test)
ENV=production

# --------------------------------------------------------------------
# Database Settings
# --------------------------------------------------------------------
# Production-ready MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/cloudfortress_node

# --------------------------------------------------------------------
# Security & Token Settings
# --------------------------------------------------------------------
# Strong secret key for signing JWT Access Tokens (Min. 32 chars)
JWT_SECRET=production_access_jwt_super_secret_key_change_me_9988
# Strong secret key for signing JWT Refresh Tokens (Min. 32 chars)
JWT_REFRESH_SECRET=production_refresh_jwt_super_secret_key_change_me_9988

# --------------------------------------------------------------------
# Email (SMTP) Settings (Optional - Falls back to mock spooler if empty)
# --------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=security@cloudfortress.ai
