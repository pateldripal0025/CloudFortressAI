# ==============================================================================
# CloudFortress AI: FastAPI AI Engine Production Environment Template
# ==============================================================================

# Server Context
ENV=production
LOG_LEVEL=info
PORT=8000

# MongoDB Database Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/cloudfortress
DB_NAME=cloudfortress_ai

# Redis Realtime Cache & Socket Coordination
REDIS_URL=redis://default:<password>@host.railway.internal:6379/0

# Cryptographic Keys
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

WEBHOOK_SECRET=your_webhook_secret_here

# CORS Settings
ALLOWED_ORIGINS=https://cloudfortress.ai,https://admin.cloudfortress.ai,http://localhost:3000,http://localhost:5173

# External Services
EXPRESS_GATEWAY_URL=http://localhost:5000